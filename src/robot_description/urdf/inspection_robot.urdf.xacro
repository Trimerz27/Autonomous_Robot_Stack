<?xml version="1.0"?>

<robot name="inspection_robot"
       xmlns:xacro="http://ros.org/wiki/xacro">


  <!-- Base -->
  <link name="base_link">

    <visual>
      <geometry>
        <box size="1.0 0.6 0.3"/>
      </geometry>

      <material name="blue">
        <color rgba="0 0.2 0.8 1"/>
      </material>

    </visual>


    <collision>
      <geometry>
        <box size="1.0 0.6 0.3"/>
      </geometry>
    </collision>


    <inertial>
      <mass value="10"/>
      <inertia
        ixx="0.1"
        ixy="0"
        ixz="0"
        iyy="0.1"
        iyz="0"
        izz="0.1"/>
    </inertial>

  </link>



  <!-- Left wheel -->
  <link name="left_wheel">

    <visual>
      <geometry>
        <cylinder radius="0.15" length="0.1"/>
      </geometry>

    </visual>

  </link>


  <joint name="left_wheel_joint"
         type="continuous">

    <parent link="base_link"/>
    <child link="left_wheel"/>

    <origin xyz="0 0.35 -0.15"
            rpy="1.5708 0 0"/>

    <axis xyz="0 1 0"/>

  </joint>



  <!-- Right wheel -->
  <link name="right_wheel">

    <visual>
      <geometry>
        <cylinder radius="0.15" length="0.1"/>
      </geometry>

    </visual>

  </link>


  <joint name="right_wheel_joint"
         type="continuous">

    <parent link="base_link"/>
    <child link="right_wheel"/>

    <origin xyz="0 -0.35 -0.15"
            rpy="1.5708 0 0"/>

    <axis xyz="0 1 0"/>

  </joint>


</robot>

